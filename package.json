{
  "name": "golden-italy-experience",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build && vite build --ssr src/entry-server.tsx --outDir dist-ssr && node scripts/prerender.mjs && npm run seo:check && npm run structured-data:check",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "seo:check": "node scripts/seo-check.mjs",
    "structured-data:check": "node scripts/structured-data-check.mjs",
    "prerender:check": "node scripts/prerender-check.mjs",
    "validate": "npm run typecheck && npm run build && npm run seo:check && npm run structured-data:check && npm run prerender:check"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "gsap": "^3.13.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.61.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
